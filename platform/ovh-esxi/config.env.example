# platform/ovh-esxi configuration.
# Copy to config.env (gitignored) and edit for your site. All scripts in this
# folder source ./config.env if present; otherwise the built-in defaults apply.

# --- hypervisor / provisioning (make-rocky-vm.sh) ---
# SSH target for the ESXi host.
ESXI=root@esxi.example.net
# VMFS datastore path on the hypervisor.
DATASTORE=/vmfs/volumes/datastore1
# Isolated portgroup where VMs live (see setup-master-nat/dhcp).
PORTGROUP=Internal
# Golden Rocky image, cloned per VM. Build once (see README "golden image").
BASE_VMDK=/vmfs/volumes/datastore1/images/Rocky-9-base.vmdk
# Default VM sizing.
MEM=2048
CPUS=1
# Grow the cloned root disk to this size before first boot (cloud-init growpart
# extends root to fill it). Empty/unset keeps the golden image's size (10G).
# A build/control host that runs k3s + image builds wants e.g. 40G.
#DISK=40G

# --- internal network (shared) ---
# The gateway's Internal-side address and the Internal network. The prefix in
# INT_CIDR is reused for the gateway seed's static int address.
INT_ADDR=10.10.10.1
INT_CIDR=10.10.10.0/24
# DHCP pool, gateway, and resolver handed to VMs (consumed by the ansible gateway
# role's dnsmasq config; mirror these in roles/gateway vars or pass as extra-vars).
DHCP_RANGE=10.10.10.50,10.10.10.150,12h
DHCP_ROUTER=10.10.10.1
DHCP_DNS=8.8.8.8

# --- gateway VM (make-rocky-vm.sh -g) ---
# The always-on NAT/DHCP box. It IS the DHCP server, so it gets STATIC networking
# on BOTH NICs from the seed (not DHCP). Buy the public IP + generate the virtual
# MAC at the provider (OVH/Kimsufi) — the one accepted out-of-band manual step.
# Public uplink portgroup (where the provider-routable NIC lives).
PUB_PORTGROUP="VM Network"
# Provider virtual MAC for the public NIC (provider-generated).
OVH_MAC=02:00:00:00:00:00
# Public IP / prefix / default gateway / resolver for the gateway itself.
PUB_ADDR=203.0.113.10
PUB_PREFIX=24
PUB_GW=203.0.113.254
PUB_DNS=8.8.8.8
# Internal NIC MAC — VMware OUI range, pinned so the seed matches it by MAC.
INT_MAC=00:50:56:10:10:01
